# Normalize all text files to LF on commit
* text=auto eol=lf

# Explicitly declare binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.pdf binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.zip binary
*.apk binary
*.ipa binary
*.so binary
*.dylib binary
*.dll binary
